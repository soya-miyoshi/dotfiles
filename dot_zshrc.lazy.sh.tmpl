# Assign a deterministic color theme to a tmux session based on its name.
# The hash of the session name picks from a curated palette so each project
# gets a distinct, stable color for the status bar.
__tmux_apply_session_theme() {
    local session="$1"
    local -a palette=(
        "fg=#1d1f21,bg=#81a2be"   # blue
        "fg=#1d1f21,bg=#b5bd68"   # green
        "fg=#1d1f21,bg=#f0c674"   # yellow
        "fg=#1d1f21,bg=#cc6666"   # red
        "fg=#1d1f21,bg=#b294bb"   # purple
        "fg=#1d1f21,bg=#8abeb7"   # cyan
        "fg=#1d1f21,bg=#de935f"   # orange
        "fg=#1d1f21,bg=#a3685a"   # brown
    )
    local hash=$(printf '%s' "$session" | cksum | awk '{print $1}')
    local idx=$(( hash % ${#palette[@]} + 1 ))
    local style="${palette[$idx]}"
    local bg="${style##*bg=}"

    # Convert hex color to RGB for iTerm tab color escape sequence
    local r=$((16#${bg:1:2})) g=$((16#${bg:3:2})) b=$((16#${bg:5:2}))

    tmux set-option -t "$session" status-left "#[${style},bold] [#S] #[default] " \; \
         set-option -t "$session" status-style "fg=${bg},bg=default"

    # Set iTerm2 tab color to match the session theme
    printf "\033]6;1;bg;red;brightness;%d\a" "$r"
    printf "\033]6;1;bg;green;brightness;%d\a" "$g"
    printf "\033]6;1;bg;blue;brightness;%d\a" "$b"
}

# Re-roll the current tmux session's color theme
tmux-theme() {
    if [ -z "$TMUX" ]; then
        echo "Not inside tmux" >&2
        return 1
    fi
    __tmux_apply_session_theme "$(tmux display-message -p '#S')"
}

# ghq + tmux session helper
widget::ghq::source() {
    local session color icon green="\e[32m" blue="\e[34m" reset="\e[m" checked="✔" unchecked="✖"
    local sessions=($(tmux list-sessions -F "#S" 2>/dev/null))

    ghq list | sort | while read -r repo; do
        session="${${repo##*/}//[:. ]/-}"
        color="$blue"
        icon="$unchecked"
        if (( ${+sessions[(r)$session]} )); then
            color="$green"
            icon="$checked"
        fi
        printf "$color$icon %s$reset\n" "$repo"
    done
}
widget::ghq::select() {
    local root="$(ghq root)"
    widget::ghq::source | fzf --exit-0 --preview="fzf-preview-git ${(q)root}/{+2}" --preview-window="right:60%" | cut -d' ' -f2-
}
widget::ghq::session() {
    local selected="$(widget::ghq::select)"
    if [ -z "$selected" ]; then
        return
    fi

    local repo_dir="$(ghq list --exact --full-path "$selected")"
    local session_name="${${selected##*/}//[:. ]/-}"
    echo $session_name

    if [ -z "$TMUX" ]; then
        BUFFER="tmux new-session -A -s ${(q)session_name} -c ${(q)repo_dir}"
        cd $repo_dir
        zle accept-line
    elif [ "$(tmux display-message -p "#S")" = "$session_name" ] && [ "$PWD" != "$repo_dir" ]; then
        BUFFER="cd ${(q)repo_dir}"
        zle accept-line
    else
        tmux new-session -d -s "$session_name" -c "$repo_dir" 2>/dev/null
        __tmux_apply_session_theme "$session_name"
        tmux switch-client -t "$session_name"
    fi
    zle -R -c
}
zle -N widget::ghq::session
bindkey "^G" widget::ghq::session

# Git branch picker
widget::git::source() {
    git branch --all --color=always | sed 's/^[ *]*//;s/ ->.*//;s/HEAD/HEAD /' | sort | while read -r branch; do
        printf "%s\n" "$branch"
    done
}
widget::git::select() {
    widget::git::source | fzf --exit-0 | cut -d' ' -f2-
}
widget::git::checkout() {
    printf "git switch "
    local selected="$(widget::git::select)"
    if [ -n "$selected" ]; then
        BUFFER="git switch ${(q)selected}"
        zle accept-line
    fi
}
zle -N widget::git::checkout
bindkey "^s" widget::git::checkout

