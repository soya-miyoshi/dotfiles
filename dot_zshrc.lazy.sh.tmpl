# Watch GitHub Actions runs for a branch (default: main). `ghw` with no args
# watches main, `ghw my-branch` watches that branch. Uses viddy for diff
# highlight so CI status changes are easy to spot.
ghw() {
    local branch="${1:-main}"
    viddy -n 5 "gh run list --branch ${branch} --limit 10"
}
# Watch GitHub Actions runs tied to the current HEAD commit. Single-quoted
# so viddy re-evaluates `git rev-parse HEAD` each tick — new commits on the
# branch are picked up automatically without restarting.
ghwh() {
    viddy -n 5 'gh run list --commit $(git rev-parse HEAD) --limit 20'
}
# Show failing step logs for the most recent failed run on the HEAD commit.
# `gh run view --log-failed` extracts only the lines from the failed step(s),
# which is usually what you actually want to read.
ghfail() {
    local run_id
    run_id=$(gh run list \
        --commit "$(git rev-parse HEAD)" \
        --status failure \
        --limit 1 \
        --json databaseId \
        --jq '.[0].databaseId')
    if [ -z "$run_id" ]; then
        echo "No failed runs for HEAD commit" >&2
        return 1
    fi
    gh run view "$run_id" --log-failed
}

