#!/usr/bin/env bash
# Install brew packages and casks.
# Runs after install_homebrew, before chezmoi apply.
set -euo pipefail

{{ if .ci -}}
echo "[install_brew_packages] CI mode: skipping (heavy installs)"
exit 0
{{- end }}

# Ensure brew is on PATH for this script
if ! command -v brew >/dev/null 2>&1; then
{{ if eq .chezmoi.os "darwin" -}}
    if [ -x /opt/homebrew/bin/brew ]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [ -x /usr/local/bin/brew ]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi
{{- else if eq .chezmoi.os "linux" -}}
    if [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
        eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
    fi
{{- end }}
fi

if ! command -v brew >/dev/null 2>&1; then
    echo "[install_brew_packages] ERROR: brew not found, aborting"
    exit 1
fi

# Install one formula at a time so a single failure doesn't block subsequent
# packages. Skip anything already installed (cheap idempotency).
install_one() {
    local pkg="$1"
    local kind="${2:-formula}"   # formula or cask
    if [ "$kind" = "cask" ]; then
        if brew list --cask "$pkg" >/dev/null 2>&1; then
            return 0
        fi
        brew install --cask "$pkg" \
            || echo "[install_brew_packages] FAIL cask $pkg (continuing)"
    else
        if brew list --formula "$pkg" >/dev/null 2>&1; then
            return 0
        fi
        brew install "$pkg" \
            || echo "[install_brew_packages] FAIL formula $pkg (continuing)"
    fi
}

# Packages listed here are always upgraded to the latest version on every
# chezmoi apply (LazyVim etc. require a recent neovim, so we can't let it
# drift). Add a formula here when you want `chezmoi apply` to keep it fresh.
upgrade_one() {
    local pkg="$1"
    if ! brew list --formula "$pkg" >/dev/null 2>&1; then
        return 0
    fi
    brew upgrade "$pkg" \
        || echo "[install_brew_packages] FAIL upgrade $pkg (continuing)"
}

UPGRADE_FORMULAE=(
    neovim
)

# ---- Common formulae (mac + linux) ----
COMMON_FORMULAE=(
    ghq
    coreutils
    findutils
    gnu-sed
    grep
    tmux
    fzf
    neovim
    tfenv
    awscli
    direnv
    bitwarden-cli
    sops
    age
    gh
    jq
    fd
    ripgrep
    telnet
    jsonnet
    # ---- Terminal IDE stack ----
    lazygit       # git TUI used from nvim and standalone
    bat           # cat with syntax highlighting (used by fzf preview)
    eza           # modern ls replacement
    glow          # markdown renderer for the terminal
    yazi          # file manager (visual file browser in tmux)
    viddy         # modern `watch` with diff highlight (used by ghw alias)
    tree-sitter   # CLI for nvim treesitter
    luarocks      # required by some nvim plugins
)

echo "[install_brew_packages] installing common formulae..."
for pkg in "${COMMON_FORMULAE[@]}"; do
    install_one "$pkg" formula
done

echo "[install_brew_packages] upgrading pinned-fresh formulae..."
for pkg in "${UPGRADE_FORMULAE[@]}"; do
    upgrade_one "$pkg"
done

{{ if eq .chezmoi.os "darwin" }}
# ---- macOS-only formulae ----
MAC_FORMULAE=(
    nvm
    maven
    docker-compose
    kayac/tap/ecspresso
    fujiwara/tap/tfstate-lookup
    aquaproj/aqua/aqua
)
echo "[install_brew_packages] installing macOS formulae..."
for pkg in "${MAC_FORMULAE[@]}"; do
    install_one "$pkg" formula
done

# ---- macOS casks ----
MAC_CASKS=(
    iterm2
    google-chrome
    contexts
    clipy
    karabiner-elements
    session-manager-plugin
    docker
    rectangle
    git-credential-manager-core
)
echo "[install_brew_packages] installing macOS casks..."
for pkg in "${MAC_CASKS[@]}"; do
    install_one "$pkg" cask
done
{{ end }}

echo "[install_brew_packages] done."
