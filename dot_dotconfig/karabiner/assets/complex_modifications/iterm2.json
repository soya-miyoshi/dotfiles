{
  "title": "iTerm2 tweaks",
  "rules": [
    {
      "description": "Disable Cmd+H (Hide) in iTerm2",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "h",
            "modifiers": {
              "mandatory": ["command"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "vk_none"
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^com\\.googlecode\\.iterm2$"]
            }
          ]
        }
      ]
    },
    {
      "description": "Disable Cmd+R (Reset) in iTerm2",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "r",
            "modifiers": {
              "mandatory": ["command"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "vk_none"
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": ["^com\\.googlecode\\.iterm2$"]
            }
          ]
        }
      ]
    }
  ]
}
