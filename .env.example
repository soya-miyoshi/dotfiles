# Template for the dev container's .env file.
# Copy this to .env, edit values, then run ./setup.sh to populate the
# PORT_* values automatically.
#
#   cp .env.example .env
#   # edit PROJECT_NUMBER if you run multiple devcontainers in parallel
#   ./setup.sh
#   docker-compose up -d
#   ./dev-exec.sh

# Project identifier (kebab-case). Used as the container name prefix.
PROJECT_NAME=dotfiles

# 1-99. Used to derive host port numbers (avoids collisions across projects).
# Web ports become 21000+N..21900+N, API ports 22000+N..22900+N.
PROJECT_NUMBER=99

# Docker compose file (override if you have a custom one)
COMPOSE_FILE=docker-compose.yml
