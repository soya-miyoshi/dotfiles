if [[ $(uname -m) == 'arm64' ]]; then
  eval $(/opt/homebrew/bin/brew shellenv)
else
  eval "$(brew shellenv)"
fi
export HOMEBREW_NO_AUTO_UPDATE=1

zshaddhistory() {
    local line="${1%%$'\n'}"
    [[ ! "$line" =~ "^(cd|history|jj?|lazygit|la|ll|ls|rm|rmdir|trash)($| )" ]]
}

# zinitの読み込み
ZDOTDIR="$HOME"
ZINIT_HOME="${XDG_DATA_HOME:-$HOME/.local/share}/zinit/zinit.git"
if [ -f "$ZINIT_HOME/zinit.zsh" ]; then
    source "$ZINIT_HOME/zinit.zsh"
elif command -v ghq >/dev/null 2>&1 && [ -f "$(ghq root)/github.com/zdharma-continuum/zinit/zinit.zsh" ]; then
    # Legacy fallback for machines that still have zinit in ghq
    source "$(ghq root)/github.com/zdharma-continuum/zinit/zinit.zsh"
else
    echo "[zshrc] zinit not found; run 'chezmoi apply' or clone zdharma-continuum/zinit to $ZINIT_HOME" >&2
fi

# git-completionの読み込み
fpath=(~/.zsh $fpath)
zstyle ':completion:*:*:git:*' script ~/.zsh/completion/git-completion.bash
autoload -Uz compinit
if [[ -n "$HOME/.zcompdump"(#qN.mh+24) ]]; then
    compinit
else
    compinit -C
fi

# git-promptの読み込み
source $ZDOTDIR/.zsh/completion/git-prompt.sh
GIT_PS1_SHOWDIRTYSTATE=true
GIT_PS1_SHOWUNTRACKEDFILES=true
GIT_PS1_SHOWSTASHSTATE=true
GIT_PS1_SHOWUPSTREAM=auto
setopt PROMPT_SUBST ; PS1='%F{green}%n@%m%f: %F{cyan}%~%f %F{red}$(__git_ps1 "(%s)")%f
\$ '

